#!/usr/bin/env python3
import os
import logging
import time
import threading
from datetime import datetime

import requests
import mysql.connector
from flask import Flask, jsonify

# Cấu hình logging
log_dir = "/app/logs"
os.makedirs(log_dir, exist_ok=True)
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    handlers=[
        logging.FileHandler(os.path.join(log_dir, "crawler.log")),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger(__name__)

# Biến môi trường
MYSQL_HOST = os.getenv("MYSQL_HOST", "localhost")
MYSQL_PORT = int(os.getenv("MYSQL_PORT", 3306))
MYSQL_DATABASE = os.getenv("MYSQL_DATABASE", "labdb")
MYSQL_USER = os.getenv("MYSQL_USER", "labuser")
MYSQL_PASSWORD = os.getenv("MYSQL_PASSWORD", "labpass")

app = Flask(__name__)

def init_db():
    """Tạo bảng nếu chưa tồn tại"""
    try:
        conn = mysql.connector.connect(
            host=MYSQL_HOST,
            port=MYSQL_PORT,
            user=MYSQL_USER,
            password=MYSQL_PASSWORD,
            database=MYSQL_DATABASE
        )
        cursor = conn.cursor()
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS crawler_data (
                id INT AUTO_INCREMENT PRIMARY KEY,
                url VARCHAR(255) NOT NULL,
                status_code INT,
                response_time FLOAT,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        """)
        conn.commit()
        cursor.close()
        conn.close()
        logger.info("Database initialized successfully")
    except Exception as e:
        logger.error(f"Failed to init database: {e}")

def crawl_url(url):
    """Crawl một URL và lưu kết quả vào DB"""
    start = time.time()
    try:
        resp = requests.get(url, timeout=10)
        status = resp.status_code
    except Exception as e:
        status = 0
        logger.error(f"Error crawling {url}: {e}")
    elapsed = time.time() - start
    
    try:
        conn = mysql.connector.connect(
            host=MYSQL_HOST,
            port=MYSQL_PORT,
            user=MYSQL_USER,
            password=MYSQL_PASSWORD,
            database=MYSQL_DATABASE
        )
        cursor = conn.cursor()
        cursor.execute(
            "INSERT INTO crawler_data (url, status_code, response_time) VALUES (%s, %s, %s)",
            (url, status, elapsed)
        )
        conn.commit()
        cursor.close()
        conn.close()
        logger.info(f"Crawled {url} - Status: {status}, Time: {elapsed:.2f}s")
    except Exception as e:
        logger.error(f"Failed to save crawl result: {e}")

def crawler_loop():
    """Vòng lặp crawl định kỳ"""
    urls = [
        "https://httpbin.org/status/200",
        "https://httpbin.org/status/404",
        "https://httpbin.org/delay/1"
    ]
    while True:
        for url in urls:
            crawl_url(url)
            time.sleep(5)  # Nghỉ 5 giây giữa các lần crawl
        logger.info("Completed one crawl cycle. Sleeping for 60 seconds.")
        time.sleep(60)

@app.route('/')
def index():
    return jsonify({"service": "tool-crawler", "status": "running"})

@app.route('/data')
def get_data():
    """API lấy dữ liệu crawl gần đây"""
    try:
        conn = mysql.connector.connect(
            host=MYSQL_HOST,
            port=MYSQL_PORT,
            user=MYSQL_USER,
            password=MYSQL_PASSWORD,
            database=MYSQL_DATABASE
        )
        cursor = conn.cursor(dictionary=True)
        cursor.execute("SELECT * FROM crawler_data ORDER BY created_at DESC LIMIT 20")
        rows = cursor.fetchall()
        cursor.close()
        conn.close()
        return jsonify(rows)
    except Exception as e:
        return jsonify({"error": str(e)}), 500

if __name__ == "__main__":
    # Khởi tạo DB
    init_db()
    
    # Chạy crawler trong thread riêng
    crawler_thread = threading.Thread(target=crawler_loop, daemon=True)
    crawler_thread.start()
    
    # Chạy Flask web server
    app.run(host='0.0.0.0', port=5000, debug=False)
